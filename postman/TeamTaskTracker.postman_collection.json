    {
      "name": "⚡ RBAC Error Cases",
      "description": "Demonstrates RBAC enforcement — these requests should return 403 FORBIDDEN when called with the correct role restrictions.",
      "item": [
        {
          "name": "MEMBER tries to create a task (expect 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Unauthorized task\",\n  \"project_id\": \"{{projectId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Login as a MEMBER user first, then call this. Should return 403 FORBIDDEN since only ADMIN/MANAGER can create tasks."
          }
        },
        {
          "name": "MANAGER tries to create a user (expect 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
