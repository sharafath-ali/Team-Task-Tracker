{
  "info": {
    "_postman_id": "ttt-2024-collection-v1",
    "name": "Team Task Tracker API",
    "description": "Complete REST API collection for the Team Task Tracker assignment.\n\n**Base URL:** `http://localhost:5000`\n\n**How to use:**\n1. Run `docker compose up` in the project root\n2. Call **Auth → Register** to create your org + admin account\n3. Call **Auth → Login** — the collection auto-saves the `accessToken` and `refreshToken` into collection variables\n4. All authenticated requests use `{{accessToken}}` automatically\n\n**Swagger UI:** http://localhost:5000/api/docs\n\n**Roles:** ADMIN | MANAGER | MEMBER\n\n**Task status transitions (server-enforced):**\n```\nTODO → IN_PROGRESS → IN_REVIEW → DONE\n  \\          \\            /\n   \\──────────► BLOCKED ◄─\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orgId",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string"
    },
    {
      "key": "memberId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔒 Auth",
      "description": "Authentication endpoints — register, login, token rotation, logout, and current user profile.",
      "item": [
        {
          "name": "Register (create org + admin user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',  body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "  pm.collectionVariables.set('userId',       body.data.user.id);",
                  "  pm.collectionVariables.set('orgId',        body.data.user.org_id);",
                  "  pm.test('Register successful', () => pm.expect(pm.response.code).to.equal(201));",
                  "  pm.test('Has access token',   () => pm.expect(body.data.accessToken).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orgName\": \"Acme Corp\",\n  \"name\": \"Alice Smith\",\n  \"email\": \"alice@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Creates a new organization and the first ADMIN user. Returns an access token (15m TTL) and a refresh token (7d TTL)."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',  body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "  pm.collectionVariables.set('userId',       body.data.user.id);",
                  "  pm.collectionVariables.set('orgId',        body.data.user.org_id);",
                  "  pm.test('Login successful',  () => pm.expect(pm.response.code).to.equal(200));",
                  "  pm.test('Has access token',  () => pm.expect(body.data.accessToken).to.be.a('string'));",
                  "  pm.test('Has refresh token', () => pm.expect(body.data.refreshToken).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Returns accessToken (15m) and refreshToken (7d). The test script auto-saves both into collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',  body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "  pm.test('Token rotated',    () => pm.expect(pm.response.code).to.equal(200));",
                  "  pm.test('New access token', () => pm.expect(body.data.accessToken).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Rotates the refresh token — the old token is revoked immediately, a new pair is issued."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Revokes the provided refresh token. Future refresh calls with this token will return 401."
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the authenticated user's profile along with their organization details."
          }
        }
      ]
    },
    {
      "name": "👥 Users",
      "description": "User management. LIST is accessible to ADMIN and MANAGER. All mutations (create, update, delete) are ADMIN-only.",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page",  "value": "1"  },
                { "key": "limit", "value": "20" },
                { "key": "role",  "value": "",  "description": "Filter by role: ADMIN | MANAGER | MEMBER", "disabled": true }
              ]
            },
            "description": "Lists all active users in the authenticated user's organization. Supports pagination and role filtering."
          }
        },
        {
          "name": "Create User (ADMIN only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('memberId', body.data.id);",
                  "  pm.test('User created', () => pm.expect(pm.response.code).to.equal(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Manager\",\n  \"email\": \"bob@acme.com\",\n  \"password\": \"password123\",\n  \"role\": \"MANAGER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Creates/invites a new user into the organization. ADMIN only. Valid roles: ADMIN, MANAGER, MEMBER."
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{memberId}}"]
            }
          }
        },
        {
          "name": "Update User (ADMIN only)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"MEMBER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{memberId}}"]
            },
            "description": "Update a user's role or is_active status. ADMIN only."
          }
        },
        {
          "name": "Deactivate User (ADMIN only)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/users/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{memberId}}"]
            },
            "description": "Soft-deactivates a user (sets is_active = false). ADMIN only. User is not deleted from DB."
          }
        }
      ]
    },
    {
