    {
      "name": "✅ Tasks",
      "description": "Task management with enforced status transitions and Redis caching.\n\n**Status state machine:**\n- TODO → IN_PROGRESS, BLOCKED\n- IN_PROGRESS → IN_REVIEW, BLOCKED\n- IN_REVIEW → DONE, IN_PROGRESS, BLOCKED\n- BLOCKED → TODO, IN_PROGRESS\n- DONE → (terminal)\n\n**MEMBER** can only see/update tasks assigned to them. Task list responses are cached in Redis.",
      "item": [
        {
          "name": "List Tasks (paginated + filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "page",     "value": "1"           },
                { "key": "limit",    "value": "20"          },
                { "key": "status",   "value": "TODO",       "disabled": true, "description": "TODO | IN_PROGRESS | IN_REVIEW | DONE | BLOCKED" },
                { "key": "priority", "value": "HIGH",       "disabled": true, "description": "LOW | MEDIUM | HIGH" },
                { "key": "assignee", "value": "{{memberId}}","disabled": true, "description": "UUID of assignee — ignored for MEMBER role" },
                { "key": "project_id","value": "{{projectId}}","disabled": true }
              ]
            },
            "description": "Returns paginated task list. MEMBER role is forced to see only their own tasks regardless of the `assignee` filter. Responses are served from Redis cache when available."
          }
        },
        {
          "name": "Create Task (ADMIN / MANAGER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('taskId', body.data.id);",
                  "  pm.test('Task created', () => pm.expect(pm.response.code).to.equal(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design homepage mockup\",\n  \"description\": \"Create Figma mockup for the new homepage based on the updated brand guide.\",\n  \"priority\": \"HIGH\",\n  \"project_id\": \"{{projectId}}\",\n  \"assignee_id\": \"{{memberId}}\",\n  \"due_date\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a new task. `project_id` is required. `assignee_id` must be a user in the same organization. Initial status is always TODO."
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Returns full task details including assignee name, creator name, and project name. MEMBER can only access tasks assigned to them."
          }
        },
        {
          "name": "Update Task Fields",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design homepage mockup (revised)\",\n  \"description\": \"Updated scope — include mobile breakpoints.\",\n  \"priority\": \"MEDIUM\",\n  \"due_date\": \"2024-11-30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Update task title, description, priority, assignee, or due_date. Does NOT change status — use the /status endpoint for that. MEMBER can only update tasks assigned to them."
          }
        },
        {
          "name": "Advance Task Status → IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "status"]
            },
            "description": "Enforced state machine. TODO → IN_PROGRESS is valid. An invalid transition (e.g. TODO → DONE) will return 422 INVALID_TRANSITION. Only the assignee or MANAGER/ADMIN can call this."
          }
        },
        {
          "name": "Advance Task Status → IN_REVIEW",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_REVIEW\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "status"]
            }
          }
        },
        {
          "name": "Advance Task Status → DONE",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "status"]
            },
            "description": "Sets completed_at timestamp. DONE is a terminal state — no further transitions allowed."
          }
        },
        {
          "name": "Block a Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BLOCKED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "status"]
            },
            "description": "BLOCKED is reachable from TODO, IN_PROGRESS, or IN_REVIEW."
          }
        },
        {
          "name": "Invalid Transition (expect 422)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}", "status"]
            },
            "description": "Demonstrates server-side transition enforcement. If current status is TODO, jumping directly to DONE returns 422 INVALID_TRANSITION."
          }
        },
        {
          "name": "Delete Task (ADMIN / MANAGER)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          }
        }
      ]
    },
