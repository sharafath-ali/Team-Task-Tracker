# ─────────────────────────────────────────────────────────────────
# Team Task Tracker — Environment Variables
# Copy this file to .env — docker compose up works with defaults
# ─────────────────────────────────────────────────────────────────

# App
NODE_ENV=development

# PostgreSQL (Docker default — works out of the box)
POSTGRES_USER=taskadmin
POSTGRES_PASSWORD=taskpassword
POSTGRES_DB=tasktracker

# Redis (Docker default)
REDIS_PASSWORD=redispassword

# JWT — CHANGE THESE IN PRODUCTION
JWT_ACCESS_SECRET=dev_access_secret_minimum_32_characters_here
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_characters_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cache TTL in seconds (default: 5 minutes)
CACHE_TTL_SECONDS=300

# ─────────────────────────────────────────────────────────────────
# SUPABASE OPTION (your personal dev — swap DATABASE_URL below)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
#
# REDIS CLOUD OPTION (your personal dev — swap REDIS_URL below)
# REDIS_URL=redis://:[PASSWORD]@[HOST]:[PORT]
# ─────────────────────────────────────────────────────────────────
